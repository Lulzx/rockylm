# Response mode: pack = ONLY OpenPeon Rocky clips (text == voice, instant);
#               llm  = RockyLM text + ROCKY_TTS voice
ROCKY_MODE=pack
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
# Voice backend: peon (recorded clips, default) or xtts (neural clone, needs `pip install TTS`)
ROCKY_TTS=peon
# Whisper model size for voice-note transcription: tiny|base|small|medium
WHISPER_MODEL=base
# Optional: route Telegram through a proxy you trust (if Telegram is blocked on
# your network). http(s):// or socks5:// (socks needs: pip install "httpx[socks]")
# TELEGRAM_PROXY=socks5://127.0.0.1:1080
